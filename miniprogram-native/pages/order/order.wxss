.order-page {
  min-height: 100vh;
  padding: 24rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #969799;
}

.value {
  font-size: 28rpx;
  color: #323233;
}

.price {
  color: #ee0a24;
  font-weight: bold;
}

.pay-section {
  margin-top: 32rpx;
}

.pay-btn {
  height: 88rpx;
  font-size: 32rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 44rpx;
  border: none;
}

.pay-btn[disabled] {
  background: #a0c8f0;
}

.pay-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #969799;
  margin-top: 16rpx;
}

.progress-section {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #323233;
  margin-bottom: 24rpx;
  display: block;
}

.task-item {
  margin-bottom: 24rpx;
}

.task-item:last-child {
  margin-bottom: 0;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.task-name {
  font-size: 28rpx;
  color: #323233;
}

.task-status {
  font-size: 24rpx;
}

.task-error {
  display: block;
  font-size: 24rpx;
  color: #ee0a24;
  margin-top: 8rpx;
}

.success-section {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.success-text {
  font-size: 32rpx;
  color: #07c160;
}