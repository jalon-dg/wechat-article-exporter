.index-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f5f5 0%, #fff 100%);
  padding: 48rpx 32rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #323233;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #969799;
  text-align: center;
  padding: 0 32rpx;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #646566;
  margin-bottom: 16rpx;
}

.input {
  font-size: 30rpx;
  color: #323233;
  width: 100%;
}

.price-info {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  margin: 16rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #646566;
}

.price-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ee0a24;
}

.submit-btn {
  margin-top: 16rpx;
  height: 88rpx;
  font-size: 32rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 44rpx;
  border: none;
}

.submit-btn[disabled] {
  background: #a0c8f0;
}

.submit-btn.loading {
  background: #a0c8f0;
}

.features {
  display: flex;
  justify-content: space-around;
  padding: 48rpx 0;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #323233;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #969799;
}