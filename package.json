{
  "name": "wechat-article-exporter",
  "version": "2.3.11",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "nohoist": [
      "**/better-sqlite3",
      "**/better-sqlite3/**"
    ]
  },
  "main": "apps/electron/main.js",
  "scripts": {
    "web:debug": "yarn --cwd apps/web debug",
    "web:dev": "yarn --cwd apps/web dev",
    "web:build": "yarn --cwd apps/web build",
    "web:preview": "yarn --cwd apps/web preview",
    "miniapp:dev": "PORT=3001 yarn --cwd apps/miniapp/server dev",
    "miniapp:build": "yarn --cwd apps/miniapp/server build",
    "miniapp:native:dev": "yarn --cwd apps/miniapp/native dev",
    "miniapp:native:build": "yarn --cwd apps/miniapp/native build",
    "dev": "yarn web:dev",
    "dev:electron": "concurrently -k \"yarn web:dev\" \"yarn electron:watch\"",
    "electron:watch": "tsc -p apps/electron/tsconfig.electron.json --watch",
    "electron:start": "tsc -p apps/electron/tsconfig.electron.json && electron apps/electron --dev",
    "build": "yarn web:build",
    "build:electron": "yarn web:build && tsc -p apps/electron/tsconfig.electron.json && electron-builder",
    "build:electron:win": "yarn web:build && tsc -p apps/electron/tsconfig.electron.json && electron-builder --win",
    "format": "biome check --write",
    "postinstall": "node ./scripts/postinstall.mjs",
    "docker:build": "docker build --build-arg VERSION=$npm_package_version -t ghcr.io/wechat-article/wechat-article-exporter:$npm_package_version .",
    "docker:publish": "docker push ghcr.io/wechat-article/wechat-article-exporter:$npm_package_version",
    "dev:multi": "bash scripts/start-dev.sh",
    "dev:monitor": "bash scripts/monitor-agent.sh",
    "dev:status": "bash scripts/multi-dev.sh status"
  },
  "dependencies": {
    "@ag-grid-community/locale": "^34.0.0",
    "@iconify-json/famicons": "^1.2.0",
    "@iconify-json/heroicons": "^1.2.2",
    "@iconify-json/heroicons-solid": "^1.2.1",
    "@nuxt/icon": "^1.3.1",
    "@nuxt/ui": "^2.17.0",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@sentry/nuxt": "^10.27.0",
    "@vueuse/components": "^10.11.0",
    "@vueuse/core": "^10.11.0",
    "@vueuse/nuxt": "^10.11.0",
    "ag-grid-enterprise": "^34.0.0",
    "ag-grid-vue3": "^34.0.0",
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.1.2",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.12",
    "defu": "^6.1.4",
    "dexie": "^4.0.11",
    "dompurify": "^3.2.5",
    "electron-log": "^5.2.4",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "happy-dom": "^20.1.0",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^0.441.0",
    "mime": "^4.0.4",
    "monaco-editor": "^0.54.0",
    "nuxt": "^3.12.3",
    "nuxt-monaco-editor": "1.4.0",
    "nuxt-umami": "3.2.1",
    "p-queue": "^8.0.1",
    "turndown": "^7.2.0",
    "uuid": "^11.0.3",
    "v-calendar": "^3.1.2",
    "vue": "^3.5.22",
    "vue-shadow-dom": "^4.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@electron/asar": "^3.3.1",
    "@types/file-saver": "^2.0.7",
    "@types/turndown": "^5.0.5",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "prettier": "^3.5.2",
    "tailwindcss-debug-screens": "^2.2.1",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@1.22.22",
  "build": {
    "appId": "com.wechat.article.exporter",
    "productName": "微信文章导出器",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "apps/web/.output/**/*",
      "apps/electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": ["dmg"],
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}